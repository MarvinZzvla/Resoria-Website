---
import type { SiteContent } from '../types/content';
import YouTubeEmbed from './YouTubeEmbed.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { successSection } = content;
const playLabel = content.locale === 'en' ? 'Play video' : 'Reproducir video';
---

<section id={successSection.id} class="py-12 md:py-14" aria-labelledby="success-heading">
  <div class="mx-auto w-[min(1120px,92vw)]">
    <header class="mb-8 text-center" data-animate>
      <h2 id="success-heading" class="mb-3 text-3xl font-bold md:text-4xl">{successSection.title}</h2>
      <p class="mx-auto max-w-xl text-resoria-muted">{successSection.subtitle}</p>
    </header>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {successSection.stories.map((story, index) => (
        <article
          class="overflow-hidden rounded-2xl border border-white/10 bg-resoria-card transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:shadow-xl hover:shadow-black/30"
          data-animate
          style={`--delay: ${index * 0.1}s`}
        >
          <YouTubeEmbed videoId={story.videoId} title={story.title} playLabel={playLabel} />
          <div class="p-5">
            <h3 class="mb-2 text-lg font-semibold">{story.title}</h3>
            <blockquote cite={`#story-${index}`} class="mb-2">
              <p class="text-sm text-resoria-muted italic">&ldquo;{story.quote}&rdquo;</p>
            </blockquote>
            <cite class="text-xs text-resoria-silver not-italic">&mdash; {story.author}</cite>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
