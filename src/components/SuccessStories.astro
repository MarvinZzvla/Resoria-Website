---
import type { SiteContent } from '../types/content';
import YouTubeEmbed from './YouTubeEmbed.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { successSection } = content;
const playLabel = content.locale === 'en' ? 'Play video' : 'Reproducir video';
---

<section id={successSection.id} class="pt-0 pb-12 md:pb-14" aria-labelledby="success-heading">
  <div class="mx-auto w-[min(1120px,92vw)]">
    <header class="mb-10 text-center" data-animate>
      <h2 id="success-heading" class="mb-3 text-3xl font-bold md:text-4xl">{successSection.title}</h2>
      <p class="mx-auto max-w-xl text-resoria-muted">{successSection.subtitle}</p>
    </header>

    <div class="mx-auto grid max-w-5xl gap-8 sm:grid-cols-2 sm:gap-10">
      {successSection.stories.map((story, index) => (
        <article
          class="flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-resoria-card shadow-xl shadow-black/25 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:shadow-2xl hover:shadow-black/35"
          data-animate
          style={`--delay: ${index * 0.1}s`}
        >
          <YouTubeEmbed videoId={story.videoId} title={story.title} playLabel={playLabel} aspect="square" />
          <div class="flex flex-1 flex-col p-5 pt-4 text-center sm:p-6">
            <h3 class="mb-3 text-xl font-semibold">{story.title}</h3>
            <blockquote cite={`#story-${index}`} class="mb-4 flex-1">
              <p class="text-sm leading-relaxed text-resoria-muted italic sm:text-base">&ldquo;{story.quote}&rdquo;</p>
            </blockquote>
            <cite class="text-sm text-resoria-silver not-italic">&mdash; {story.author}</cite>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
