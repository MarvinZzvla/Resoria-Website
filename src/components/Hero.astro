---
import type { SiteContent } from '../types/content';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { hero } = content;
const typewriterWordsJson = JSON.stringify(hero.typewriterWords);
const seoHeadline = `${hero.headlinePrefix} ${hero.typewriterWords.join(', ')}`;
---

<section class="relative overflow-hidden pt-24 pb-6 md:pt-28 md:pb-8" aria-labelledby="hero-heading">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_20%,rgba(0,168,255,0.14),transparent),radial-gradient(ellipse_40%_40%_at_80%_70%,rgba(0,102,204,0.08),transparent)]"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto w-[min(1120px,92vw)] pt-4 md:pt-6">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <div class="mb-4 flex flex-col items-center gap-0">
        <div class="leading-[0]">
          <img
            src="/logos/resoria-transparent.png"
            alt={hero.logoAlt}
            width="640"
            height="220"
            decoding="async"
            fetchpriority="high"
            class="mx-auto block h-36 w-auto sm:h-40 md:h-48 lg:h-56"
          />
        </div>

        <h1
          id="hero-heading"
          class="mx-auto -mt-6 max-w-2xl text-center text-2xl leading-tight font-bold sm:-mt-8 sm:text-3xl md:-mt-10 md:text-4xl lg:-mt-12"
        >
          <span class="text-gradient">{hero.headlinePrefix} </span>
          <span
            class="typewriter-text bg-gradient-to-r from-resoria-blue to-[#33c4ff] bg-clip-text text-transparent drop-shadow-[0_0_18px_rgba(0,168,255,0.35)]"
            data-typewriter
            data-words={typewriterWordsJson}
            aria-live="polite"
            aria-atomic="true"
          >{hero.typewriterWords[0]}</span><span
            class="typewriter-cursor font-light text-resoria-blue"
            data-typewriter-cursor
            aria-hidden="true"
          >|</span>
          <span class="sr-only">{seoHeadline}</span>
        </h1>
      </div>

      <p class="mx-auto mb-4 max-w-lg text-base text-resoria-muted sm:text-lg">{hero.subheadline}</p>
      <a
        href={`#${content.productsSection.id}`}
        class="inline-flex items-center rounded-xl bg-gradient-to-r from-resoria-blue to-resoria-blue-dark px-8 py-3.5 text-base font-semibold text-white transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(0,168,255,0.25)]"
      >
        {hero.cta}
      </a>
    </div>
  </div>
</section>

<script>
  import '../scripts/typewriter.ts';
</script>
