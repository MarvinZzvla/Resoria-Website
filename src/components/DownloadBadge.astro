---
interface Props {
  downloadUrl: string;
  label: string;
  sublabel: string;
}

const { downloadUrl, label, sublabel } = Astro.props;

function isDownloadReady(url: string): boolean {
  return Boolean(url) && url !== '#' && !url.startsWith('#');
}

const ready = isDownloadReady(downloadUrl);
const sharedProps = {
  class: 'download-gift-badge',
};
---

{
  ready ? (
    <a href={downloadUrl} target="_blank" rel="noopener noreferrer" {...sharedProps}>
      <span class="download-gift-badge__glow" aria-hidden="true"></span>
      <span class="download-gift-badge__gift" aria-hidden="true">
        <svg class="download-gift-badge__svg" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect class="download-gift-badge__box" x="5" y="14" width="22" height="14" rx="1.5" fill="currentColor" opacity="0.9" />
          <rect class="download-gift-badge__ribbon-v" x="14.25" y="14" width="3.5" height="14" fill="white" opacity="0.35" />
          <g class="download-gift-badge__lid-group">
            <rect class="download-gift-badge__lid" x="4" y="10" width="24" height="5" rx="1.5" fill="currentColor" />
            <rect x="14.25" y="10" width="3.5" height="5" fill="white" opacity="0.35" />
            <path
              class="download-gift-badge__bow"
              d="M16 10c-2.2 0-4-1.2-4-3.2C12 5.2 13.6 4 16 4c2.4 0 4 1.2 4 2.8C20 8.8 18.2 10 16 10Z"
              fill="currentColor"
            />
            <path d="M16 7.5c-1.2-1.8-3.5-2-4.8-.8M16 7.5c1.2-1.8 3.5-2 4.8-.8" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.5" />
          </g>
        </svg>
      </span>
      <span class="download-gift-badge__text">
        <span class="download-gift-badge__label">{label}</span>
        <span class="download-gift-badge__sublabel">{sublabel}</span>
      </span>
    </a>
  ) : (
    <button type="button" {...sharedProps}>
      <span class="download-gift-badge__glow" aria-hidden="true"></span>
      <span class="download-gift-badge__gift" aria-hidden="true">
        <svg class="download-gift-badge__svg" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect class="download-gift-badge__box" x="5" y="14" width="22" height="14" rx="1.5" fill="currentColor" opacity="0.9" />
          <rect class="download-gift-badge__ribbon-v" x="14.25" y="14" width="3.5" height="14" fill="white" opacity="0.35" />
          <g class="download-gift-badge__lid-group">
            <rect class="download-gift-badge__lid" x="4" y="10" width="24" height="5" rx="1.5" fill="currentColor" />
            <rect x="14.25" y="10" width="3.5" height="5" fill="white" opacity="0.35" />
            <path
              class="download-gift-badge__bow"
              d="M16 10c-2.2 0-4-1.2-4-3.2C12 5.2 13.6 4 16 4c2.4 0 4 1.2 4 2.8C20 8.8 18.2 10 16 10Z"
              fill="currentColor"
            />
            <path d="M16 7.5c-1.2-1.8-3.5-2-4.8-.8M16 7.5c1.2-1.8 3.5-2 4.8-.8" stroke="white" stroke-width="1.2" stroke-linecap="round" opacity="0.5" />
          </g>
        </svg>
      </span>
      <span class="download-gift-badge__text">
        <span class="download-gift-badge__label">{label}</span>
        <span class="download-gift-badge__sublabel">{sublabel}</span>
      </span>
    </button>
  )
}
