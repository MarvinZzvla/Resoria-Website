---
interface Props {
  downloadUrl: string;
  label: string;
  sublabel: string;
}

const { downloadUrl, label, sublabel } = Astro.props;

function isDownloadReady(url: string): boolean {
  return Boolean(url) && url !== '#' && !url.startsWith('#');
}

const badgeClass =
  'inline-flex cursor-pointer select-none items-center gap-3 rounded-xl border border-white/20 bg-gradient-to-b from-[#1a1a24] to-[#0d0d12] px-5 py-2.5 text-white shadow-[0_4px_20px_rgba(0,0,0,0.45),inset_0_1px_0_rgba(255,255,255,0.1)] transition-all duration-200 hover:-translate-y-0.5 hover:border-resoria-blue/40 hover:shadow-[0_8px_28px_rgba(0,168,255,0.25)] active:translate-y-0 active:scale-[0.97]';
---

{isDownloadReady(downloadUrl) ? (
  <a href={downloadUrl} target="_blank" rel="noopener noreferrer" class={badgeClass}>
    <svg class="h-8 w-8 shrink-0 text-resoria-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4 4m0 0l-4-4m4 4V4" />
    </svg>
    <span class="flex flex-col items-start leading-none">
      <span class="text-[11px] font-medium tracking-wide text-resoria-muted">{label}</span>
      <span class="mt-0.5 text-lg font-bold tracking-tight">{sublabel}</span>
    </span>
  </a>
) : (
  <button type="button" class={badgeClass}>
    <svg class="h-8 w-8 shrink-0 text-resoria-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4 4m0 0l-4-4m4 4V4" />
    </svg>
    <span class="flex flex-col items-start leading-none">
      <span class="text-[11px] font-medium tracking-wide text-resoria-muted">{label}</span>
      <span class="mt-0.5 text-lg font-bold tracking-tight">{sublabel}</span>
    </span>
  </button>
)}
