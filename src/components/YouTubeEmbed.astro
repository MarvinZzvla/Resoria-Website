---
interface Props {
  videoId: string;
  title: string;
  playLabel?: string;
  aspect?: 'video' | 'short' | 'square';
}

const { videoId, title, playLabel = 'Reproducir video', aspect = 'video' } = Astro.props;
const thumbSrc = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
const embedSrc = `https://www.youtube-nocookie.com/embed/${videoId}`;
const aspectClass =
  aspect === 'short' ? 'aspect-[9/16]' : aspect === 'square' ? 'aspect-square' : 'aspect-video';
---

<div class={`relative ${aspectClass} bg-resoria-elevated`}>
  <button
    type="button"
    class="youtube-embed group absolute inset-0 h-full w-full cursor-pointer overflow-hidden border-0 p-0"
    data-embed-src={embedSrc}
    aria-label={`${playLabel}: ${title}`}
  >
    <img
      src={thumbSrc}
      alt=""
      width="480"
      height="360"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
      loading="lazy"
      decoding="async"
    />
    <span
      class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/30 transition-colors group-hover:bg-black/45 group-focus-visible:bg-black/45"
      aria-hidden="true"
    >
      <span class="flex h-14 w-14 items-center justify-center rounded-full bg-[#ff0000] shadow-[0_4px_24px_rgba(0,0,0,0.45)] transition-transform group-hover:scale-105 sm:h-16 sm:w-16">
        <svg class="ml-1 h-6 w-6 text-white sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7z"></path>
        </svg>
      </span>
    </span>
  </button>
</div>

<script>
  import '../scripts/youtube-embed.ts';
</script>
