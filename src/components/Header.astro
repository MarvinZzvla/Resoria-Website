---
import type { SiteContent } from '../types/content';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { nav } = content;
const langPath = `/${content.locale}/`;
const altPath = `/${content.alternateLocale}/`;

const navLinks = [
  { href: `#${content.productsSection.id}`, label: nav.products, hideBelow: 'sm' },
  { href: `#${content.compareSection.id}`, label: nav.licenses, hideBelow: 'md' },
  { href: `#${content.successSection.id}`, label: nav.success, hideBelow: 'md' },
] as const;

const navLinkClass =
  'relative rounded-lg px-4 py-2.5 text-sm font-semibold tracking-wide text-resoria-silver transition-all duration-300 hover:bg-white/10 hover:text-white hover:shadow-[inset_0_0_0_1px_rgba(255,255,255,0.08)]';

const hideClass = {
  sm: 'hidden sm:block',
  md: 'hidden md:block',
} as const;
---

<header class="fixed inset-x-0 top-0 z-50">
  <!-- Fondo glass + borde inferior con gradiente -->
  <div class="absolute inset-0 border-b border-white/[0.08] bg-resoria-bg/70 backdrop-blur-2xl backdrop-saturate-150"></div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-resoria-blue/60 to-transparent"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto flex h-24 w-[min(1180px,94vw)] items-center justify-between gap-4 md:h-28 lg:gap-8">
    <!-- Logo destacado con placa luminosa -->
    <a
      href={langPath}
      class="group relative flex shrink-0 items-center"
      aria-label="Resoria — Home"
    >
      <span
        class="absolute -inset-3 rounded-2xl bg-resoria-blue/0 transition-all duration-500 group-hover:bg-resoria-blue/10 group-hover:shadow-[0_0_40px_rgba(0,168,255,0.2)]"
        aria-hidden="true"
      ></span>
      <img
        src="/logos/resoria-transparent.png"
        alt="Resoria"
        width="320"
        height="110"
        decoding="async"
        class="relative h-16 w-auto transition-all duration-500 group-hover:scale-[1.04] group-hover:drop-shadow-[0_0_28px_rgba(0,168,255,0.55)] sm:h-20 md:h-24 lg:h-28"
      />
    </a>

    <!-- Nav en cápsula premium -->
    <nav
      class="flex items-center rounded-2xl border border-white/10 bg-white/[0.04] p-1.5 shadow-[0_8px_32px_rgba(0,0,0,0.35),inset_0_1px_0_rgba(255,255,255,0.06)]"
      aria-label={content.lang === 'es' ? 'Navegación principal' : 'Main navigation'}
    >
      <ul class="flex items-center gap-0.5 sm:gap-1">
        {navLinks.map((link) => (
          <li class={hideClass[link.hideBelow]}>
            <a href={link.href} class={navLinkClass}>{link.label}</a>
          </li>
        ))}

        <li class="mx-0.5 hidden h-6 w-px bg-white/10 sm:block" aria-hidden="true"></li>

        <li>
          <a
            href={`#${content.contactSection.id}`}
            class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-resoria-blue via-[#0090e0] to-resoria-blue-dark px-5 py-2.5 text-sm font-bold tracking-wide text-white shadow-[0_4px_20px_rgba(0,168,255,0.35),inset_0_1px_0_rgba(255,255,255,0.2)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_28px_rgba(0,168,255,0.5)] hover:brightness-110"
          >
            <svg class="h-4 w-4 opacity-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            {nav.contact}
          </a>
        </li>

        <li class="mx-0.5 hidden h-6 w-px bg-white/10 sm:block" aria-hidden="true"></li>

        <li>
          <a
            href={altPath}
            class="inline-flex min-w-[3rem] items-center justify-center rounded-xl border border-white/15 bg-gradient-to-b from-white/[0.08] to-white/[0.02] px-3.5 py-2.5 text-sm font-bold text-resoria-silver transition-all duration-300 hover:border-resoria-blue/40 hover:from-resoria-blue/15 hover:to-resoria-blue/5 hover:text-white hover:shadow-[0_0_20px_rgba(0,168,255,0.15)]"
            hreflang={content.alternateLocale}
            lang={content.alternateLocale}
          >
            {nav.langSwitch}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
