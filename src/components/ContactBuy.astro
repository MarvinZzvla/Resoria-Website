---
import type { SiteContent } from '../types/content';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { contactSection } = content;
const { form, contactInfo } = contactSection;

const inputClass =
  'w-full rounded-lg border border-white/10 bg-resoria-elevated px-4 py-3 text-[#f0f0f5] transition-colors duration-200 outline-none focus:border-resoria-blue';

const paymentAccent = {
  paypal: 'text-[#0070ba]',
  transfer: 'text-resoria-emerald',
  cash: 'text-resoria-orange',
} as const;
---

<section id={contactSection.id} class="py-12 md:py-14" aria-labelledby="contact-heading">
  <div class="mx-auto w-[min(1120px,92vw)]">
    <header class="mb-8 text-center" data-animate>
      <h2 id="contact-heading" class="mb-3 text-3xl font-bold md:text-4xl">{contactSection.title}</h2>
      <p class="mx-auto max-w-xl text-resoria-muted">{contactSection.subtitle}</p>
    </header>

    <ol class="mb-8 grid gap-4 sm:grid-cols-3" data-animate>
      {contactSection.steps.map((step) => (
        <li class="rounded-xl border border-white/10 bg-resoria-card p-5 transition-colors duration-300 hover:border-resoria-blue/30">
          <strong class="mb-2 block text-lg text-resoria-blue">{step.title}</strong>
          <span class="text-sm text-resoria-muted">{step.description}</span>
        </li>
      ))}
    </ol>

    <div class="grid items-start gap-10 lg:grid-cols-2">
      <div data-animate>
        <!-- Conectar después con Formspree, Netlify Forms, etc. -->
        <form
          class="flex flex-col gap-5"
          action={`mailto:${contactInfo.email}`}
          method="post"
          enctype="text/plain"
        >
          <div class="flex flex-col gap-1.5">
            <label for="contact-name" class="text-sm font-medium text-resoria-silver">{form.name}</label>
            <input type="text" id="contact-name" name="name" required autocomplete="name" class={inputClass} />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="contact-email" class="text-sm font-medium text-resoria-silver">{form.email}</label>
            <input type="email" id="contact-email" name="email" required autocomplete="email" class={inputClass} />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="contact-phone" class="text-sm font-medium text-resoria-silver">{form.phone}</label>
            <input type="tel" id="contact-phone" name="phone" autocomplete="tel" class={inputClass} />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="contact-product" class="text-sm font-medium text-resoria-silver">{form.product}</label>
            <select id="contact-product" name="product" required class={inputClass}>
              {form.productOptions.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="contact-plan" class="text-sm font-medium text-resoria-silver">{form.plan}</label>
            <select id="contact-plan" name="plan" required class={inputClass}>
              {form.planOptions.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="contact-message" class="text-sm font-medium text-resoria-silver">{form.message}</label>
            <textarea id="contact-message" name="message" rows="4" class={inputClass}></textarea>
          </div>
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-resoria-blue to-resoria-blue-dark px-6 py-3.5 font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(0,168,255,0.25)]"
          >
            {form.submit}
          </button>
        </form>

        <address class="mt-6 space-y-2 not-italic">
          <p>
            <a href={`mailto:${contactInfo.email}`} class="text-sm text-resoria-muted transition-colors hover:text-resoria-blue">
              {contactInfo.email}
            </a>
          </p>
          <p>
            <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="text-sm text-resoria-muted transition-colors hover:text-resoria-blue">
              {contactInfo.phone}
            </a>
          </p>
          <p>
            <a
              href={`https://wa.me/${contactInfo.whatsapp.replace(/\D/g, '')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-resoria-muted transition-colors hover:text-resoria-blue"
            >
              WhatsApp: {contactInfo.whatsapp}
            </a>
          </p>
        </address>
      </div>

      <aside data-animate aria-labelledby="payment-heading">
        <h3 id="payment-heading" class="mb-5 text-xl font-semibold">{contactSection.paymentTitle}</h3>
        <ul class="flex flex-col gap-4">
          {contactSection.paymentMethods.map((method) => (
            <li class="rounded-xl border border-white/10 bg-resoria-card p-5 transition-all duration-300 hover:border-white/20 hover:-translate-y-0.5">
              <strong class={`mb-1 block ${paymentAccent[method.id as keyof typeof paymentAccent] ?? ''}`}>
                {method.name}
              </strong>
              <p class="text-sm text-resoria-muted">{method.description}</p>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>
