---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LegalPage from '../../components/LegalPage.astro';
import { getContent } from '../../lib/content';
import { getLegalAlternatePaths, getLegalDocument } from '../../lib/legal';

const content = getContent('es');
const document = getLegalDocument('es', 'terms');
const alternate = getLegalAlternatePaths('terms');
---

<BaseLayout
  content={content}
  pageSeo={document.seo}
  canonicalPath="/es/terminos/"
  alternatePath={alternate.en}
>
  <LegalPage content={content} document={document} />
</BaseLayout>
